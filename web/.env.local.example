# Access gate — panelists use ?key=<this value> in the URL
NEXT_PUBLIC_ACCESS_KEY=your-access-key-here

# Anthropic API (for enrichment step)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API (for web search during enrichment)
TAVILY_API_KEY=tvly-...

# Trigger.dev secret key (for triggering tasks + retrieving run status)
TRIGGER_SECRET_KEY=tr_dev_...
